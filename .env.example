# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Sheets Configuration
# You must create a Google Cloud Project, enable Google Sheets API,
# and create a Service Account to get these credentials.
# Also, remember to share your Google Sheet with the client email address below.
GOOGLE_SHEETS_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
# Note: For the private key, replace actual line breaks with \n in the .env file if necessary, 
# or paste it exactly as is if the environment supports multiline strings.
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id"
